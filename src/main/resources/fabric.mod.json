{
  "schemaVersion": 1,
  "id": "assist-excavation",
  "version": "${version}",
  "name": "Assist Excavation",
  "description": "A client-side mining utility: a toggleable auto-miner with rectangle, sphere, tunnel, and vein modes, auto tool-switching and restocking, a lava guard, and an auto-bridge. All modes respect the server's real interaction range. Some convenience features use packet tricks that server anti-cheats can flag; a Server-Safe mode disables them.",
  "authors": ["B0bTheSkull"],
  "contributors": ["zhwuyuhehe (original Assist Excavation mod)"],
  "contact": {
    "sources": "https://github.com/B0bTheSkull/mc-assist-excavation-mod",
    "issues": "https://github.com/B0bTheSkull/mc-assist-excavation-mod/issues"
  },
  "license": "Apache-2.0",
  "icon": "assets/assist-excavation/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.b0btheskull.assistExcavation.client.AssistExcavationClient"
    ],
    "main": [
      "com.b0btheskull.assistExcavation.AssistExcavation"
    ],
    "modmenu": [
      "com.b0btheskull.assistExcavation.client.config.GUI.AssistExcavationModMenu"
    ]
  },
  "depends": {
    "fabricloader": ">=0.19.0",
    "fabric-api": ">=0.150.0",
    "minecraft": "~26.1.2"
  }
}
